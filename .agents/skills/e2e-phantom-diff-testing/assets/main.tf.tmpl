terraform {
  required_providers {
    airbyte = {
      source  = "airbytehq/airbyte"
      version = "~> 1.1.0"
    }
  }
}

provider "airbyte" {
  client_id     = "${AIRBYTE_CLOUD_CLIENT_ID}"
  client_secret = "${AIRBYTE_CLOUD_CLIENT_SECRET}"
  server_url    = "${AIRBYTE_API_URL}"
}

resource "airbyte_connection" "test" {
  source_id      = "${AIRBYTE_SOURCE_ID}"
  destination_id = "${AIRBYTE_DESTINATION_ID}"
  name           = "${NAME_PREFIX}"
  status         = "inactive"
  prefix         = "${NAME_PREFIX_UNDERSCORED}_"
  configurations = {
    streams = [
      { name = "users",     sync_mode = "full_refresh_append" },
      { name = "products",  sync_mode = "full_refresh_overwrite" },
      { name = "purchases", sync_mode = "incremental_append", cursor_field = ["updated_at"], primary_key = [["id"]] }
    ]
  }
}
